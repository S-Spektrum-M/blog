---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="title"><a href="/">{SITE_TITLE}</a></h2>
		<div class="links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/blog">blog</HeaderLink>
			<HeaderLink href="/about">about</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 2rem 1rem;
		max-width: 680px;
		margin: 0 auto;
	}
	nav {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.title {
		margin: 0;
		font-size: 1.25rem;
		font-weight: 600;
	}
	.title a {
		text-decoration: none;
		color: #000;
	}
	.links {
		display: flex;
		gap: 1rem;
	}
	.links a {
		text-decoration: none;
		color: #666;
		font-size: 0.9rem;
	}
	.links a:hover {
		color: #000;
		text-decoration: underline;
	}
	.links a.active {
		color: #000;
		font-weight: 600;
	}
</style>
